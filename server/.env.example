# 服务端口
PORT=3011
NODE_ENV=production

# 图片生成 Provider 列表
# 多个用英文逗号分隔，格式：API_KEY|OpenAI兼容接口BaseURL
IMAGE_GEN_PROVIDERS=sk-xxx|https://your-openai-compatible-endpoint

# 管理员密钥：用于查看/清空全部历史记录，请换成强随机字符串
IMAGE_GEN_ADMIN_KEY=change-me-to-a-strong-random-key

# DeepSeek 提示词优化（可选，不配置则跳过优化）
DEEPSEEK_API_KEY=
